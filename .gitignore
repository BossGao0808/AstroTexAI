# ComfyUI 嵌套 git 仓库 & 缓存（保留源码）
ComfyUI/.git/
ComfyUI/custom_nodes/*/.git/

# 保留工作流文件，但忽略日志/缓存
!ComfyUI/user/default/workflows/
ComfyUI/user/*.log
ComfyUI/user/*.db
ComfyUI/user/*.db.*
ComfyUI/temp/
ComfyUI/input/

# 模型与生成产物（大文件）
models_shared/**/*.safetensors
models_shared/**/*.ckpt
models_shared/**/*.bin
models_shared/**/*.pth
models_shared/**/*.pt
models_shared/**/*.gguf
outputs/
inputs/
output/

# Python / conda 杂项
__pycache__/
*.pyc
.venv/
.env

# 系统
.DS_Store
Thumbs.db

# 编辑器
.idea/
.vscode/
