{
  "_comment": "PixelWave SDXL 11 + ControlNet Depth 工作流（API format）。用 inputs/<depth>.png 严格约束生成的几何形状。需要：models_shared/controlnet/controlnet-depth-sdxl-1.0.safetensors。修改 LoadImage.image 字段切换不同深度图。controlnet_strength 范围 0.5-1.0：1.0=形状严格遵守深度图；0.7-0.85 给模型一些自由度发挥纹理细节；0.5 以下深度提示几乎被忽略。",
  "prompt": {
    "3": {
      "class_type": "CheckpointLoaderSimple",
      "inputs": { "ckpt_name": "pixelwave_sdxl11.safetensors" }
    },
    "4": {
      "class_type": "CLIPTextEncode",
      "inputs": {
        "text": "single hexagonal prism made of dirt and earth, top-down isometric game tile, soil texture with small pebbles and grass tufts on top, vibrant 2D game asset, clean silhouette, JRPG roguelike art style, soft natural lighting",
        "clip": ["3", 1]
      }
    },
    "5": {
      "class_type": "CLIPTextEncode",
      "inputs": {
        "text": "blurry, photorealistic, 3d render, low quality, watermark, signature, deformed, multiple objects, scattered, cluttered, jpeg artifacts",
        "clip": ["3", 1]
      }
    },
    "11": {
      "class_type": "LoadImage",
      "inputs": { "image": "depth_hex_prism.png", "upload": "image" }
    },
    "12": {
      "class_type": "ControlNetLoader",
      "inputs": { "control_net_name": "controlnet-depth-sdxl-1.0.safetensors" }
    },
    "13": {
      "class_type": "ControlNetApplyAdvanced",
      "inputs": {
        "positive": ["4", 0],
        "negative": ["5", 0],
        "control_net": ["12", 0],
        "image": ["11", 0],
        "strength": 0.85,
        "start_percent": 0.0,
        "end_percent": 1.0
      }
    },
    "6": {
      "class_type": "EmptyLatentImage",
      "inputs": { "width": 1024, "height": 1024, "batch_size": 1 }
    },
    "7": {
      "class_type": "KSampler",
      "inputs": {
        "model": ["3", 0],
        "positive": ["13", 0],
        "negative": ["13", 1],
        "latent_image": ["6", 0],
        "seed": 20260527,
        "steps": 28,
        "cfg": 5.5,
        "sampler_name": "dpmpp_sde",
        "scheduler": "karras",
        "denoise": 1.0
      }
    },
    "10": {
      "class_type": "VAELoader",
      "inputs": { "vae_name": "sdxl_vae_fp16_fix.safetensors" }
    },
    "8": {
      "class_type": "VAEDecode",
      "inputs": { "samples": ["7", 0], "vae": ["10", 0] }
    },
    "9": {
      "class_type": "SaveImage",
      "inputs": { "filename_prefix": "pixelwave_depth", "images": ["8", 0] }
    }
  }
}
