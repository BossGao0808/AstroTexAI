{
  "_comment": "PixelWave SDXL 11 测试工作流（API format）。使用 dpmpp_sde+karras / 20 steps / cfg 5.5（作者 Civitai 推荐参数）。fp16-fix VAE 显式加载，避免 SDXL 偶发偏色/全黑。",
  "prompt": {
    "3": {
      "class_type": "CheckpointLoaderSimple",
      "inputs": { "ckpt_name": "pixelwave_sdxl11.safetensors" }
    },
    "4": {
      "class_type": "CLIPTextEncode",
      "inputs": {
        "text": "pixel art, 16-bit retro RPG style, isometric view, a cozy wooden cabin in a snowy forest at dusk, warm window light, soft purple sky, clean pixel edges, vibrant limited color palette",
        "clip": ["3", 1]
      }
    },
    "5": {
      "class_type": "CLIPTextEncode",
      "inputs": {
        "text": "blurry, photorealistic, 3d render, smooth gradient, antialiasing, low quality, watermark, signature, deformed, jpeg artifacts",
        "clip": ["3", 1]
      }
    },
    "6": {
      "class_type": "EmptyLatentImage",
      "inputs": { "width": 1024, "height": 1024, "batch_size": 1 }
    },
    "7": {
      "class_type": "KSampler",
      "inputs": {
        "model": ["3", 0],
        "positive": ["4", 0],
        "negative": ["5", 0],
        "latent_image": ["6", 0],
        "seed": 20260527,
        "steps": 20,
        "cfg": 5.5,
        "sampler_name": "dpmpp_sde",
        "scheduler": "karras",
        "denoise": 1.0
      }
    },
    "10": {
      "class_type": "VAELoader",
      "inputs": { "vae_name": "sdxl_vae_fp16_fix.safetensors" }
    },
    "8": {
      "class_type": "VAEDecode",
      "inputs": { "samples": ["7", 0], "vae": ["10", 0] }
    },
    "9": {
      "class_type": "SaveImage",
      "inputs": { "filename_prefix": "pixelwave_test", "images": ["8", 0] }
    }
  }
}
